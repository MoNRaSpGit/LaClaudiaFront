{
  "name": "laclau-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:gh": "vite build --base=/LaClaudiaFront/",
    "build:gh:prod": "node ./scripts/build-gh-prod.mjs",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives",
    "preview": "vite preview",
    "deploy": "node ./scripts/deploy-gh.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:web": "playwright test",
    "test:smoke:web": "node ./scripts/smoke-web.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "bootstrap": "^5.3.3",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.11.0",
    "qrcode": "^1.5.4",
    "qz-tray": "^2.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-toastify": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.1.1",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
